DISCORD_TOKEN=your_token_here

# Comma-separated Discord user IDs allowed to send commands (besides the bot account itself)
ALLOWED_USER_IDS=123456789012345678,987654321098765432

# IANA timezone name for displaying showtimes (e.g. America/New_York, America/Chicago, America/Los_Angeles)
# If unset, the bot's system timezone is used.
TIMEZONE=

# TVheadend
TVHEADEND_URL=http://192.168.1.100:9981
TVHEADEND_USER=admin
TVHEADEND_PASS=yourpassword

# Jellyfin
JELLYFIN_URL=http://192.168.1.100:8096
JELLYFIN_API_KEY=your_api_key_here
