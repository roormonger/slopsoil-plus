# SlopSoil Encryption Key
# Generate a new key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Keep this secret and never commit it to git!
# Copy this file to .env and replace with your generated key
# A valid Fernet key is 32 bytes encoded as URL-safe base64 (43 characters ending with =)
# Example format: 8mHRQGRIl5oZcX5Dl8RxZJKbLQn2hZ6xD4E9vT3P9qE=
SLOPSOIL_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_KEY

# yt-dlp format selector for downloaded !play <URL> VODs.
# Defaults to "bestvideo+bestaudio/best" (best available video+audio). On
# hardware that can't decode AV1/4K in real time (e.g. older GPUs), pin to
# H.264 <=1080p to avoid stutter and to skip downloading 4K only to downscale it:
# YTDLP_FORMAT=bv*[vcodec^=avc1][height<=1080]+ba/b[height<=1080]
YTDLP_FORMAT=bestvideo+bestaudio/best

# Output stream quality preset (resolution/fps/bitrate together).
# One of: 720p, 1080p, 4k. Discord enforces per-account resolution/fps caps
# (e.g. 720p30 up to 4K60 by tier), so pick one your account supports.
STREAM_QUALITY=1080p

# Per-axis overrides. These take precedence over the STREAM_QUALITY preset and
# pin that axis regardless of the preset above. The values below match 1080p.
# STREAM_RESOLUTION: W:H (or WxH) STREAM_FPS: 1-60 STREAM_VIDEO_BITRATE: -b:v/-maxrate/-bufsize (CBR)
STREAM_RESOLUTION=1920:1080
STREAM_FPS=60
STREAM_VIDEO_BITRATE=6000k

# Pace each frame's RTP packets across this fraction of the frame interval
# instead of bursting them (0.0 = off; e.g. 0.75). Can reduce freezes from
# dropped packet bursts on some networks. Clamped to 0.0-0.95.
STREAM_PACKET_PACE=0.0

# Lip-sync correction in ms. Positive advances audio (fixes "audio behind");
# negative delays audio (fixes "audio ahead"). Empirical per deployment; dial in
# by testing. Clamped to +/-5000.
STREAM_AV_SYNC_MS=0

# Local media bind mounts for dev container.
# Set absolute paths to folders on your host machine. These are read-only (:ro)
# inside the container at /media/music and /media/video.
# Leave unset or empty if you don't want to mount that directory.
# MEDIA_MUSIC=/home/you/Music
# MEDIA_VIDEO=/home/you/Videos
